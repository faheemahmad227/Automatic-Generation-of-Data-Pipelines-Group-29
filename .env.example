# Data Pipeline Generator - Environment Variables
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-change-in-production
FLASK_DEBUG=True

# AI Gateway Configuration (Uni Paderborn)
# Use this for the university AI Gateway
AI_GATEWAY_URL=https://ai-gateway.2.2021.2.2.2.2.2.2
AI_GATEWAY_API_KEY=your-ai-gateway-key

# OpenAI Configuration (Alternative)
# Use this if you have an OpenAI API key
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Note: The application will work without an API key,
# but AI-powered features (intelligent code generation,
# recommendations) will use fallback templates instead.
